@inject GameService GameService
@inject GameEventBus EventBus
@implements IDisposable

@if (_notFound)
{
    <div class="game-layout">
        <div class="card" style="text-align:center; padding:40px;">
            <h2>⚠️ Game Not Found</h2>
            <p style="margin:16px 0; color:var(--muted)">This game does not exist or has been removed.</p>
            <a class="btn btn-primary btn-lg" href="/">← Back to Home</a>
        </div>
    </div>
}
else if (_state is null)
{
    <div class="game-layout">
        <p><em>Loading game...</em></p>
    </div>
}
else
{
    <div class="game-root">
        <div class="game-sidebar">
            <RoleCard State="@_state" />
            <PlayerList State="@_state" />
            <QuestTrack State="@_state" />
        </div>
        <div class="game-panels">
            <div class="panel-action">
                <PhaseBar State="@_state" />

                @if (_state.IsObserver)
                {
                    <div class="card" style="background:#1a2a4a; border:1px solid #2d4a7a;">
                        <h3>👁️ Observer Mode</h3>
                        <p style="color:var(--muted)">You joined after the game started. You can watch the game progress and chat with players, but cannot take actions until the next game.</p>
                    </div>
                }
                else
                {
                    @switch (_state.Phase)
                    {
                        case "Lobby":
                            <LobbyPanel GameId="@GameId" PlayerId="@PlayerId" State="@_state" OnAction="@RefreshState" />
                            break;
                        case "TeamProposal":
                            <TeamProposalPanel GameId="@GameId" PlayerId="@PlayerId" State="@_state" OnAction="@RefreshState" />
                            break;
                        case "TeamVote":
                            <VotePanel GameId="@GameId" PlayerId="@PlayerId" State="@_state" OnAction="@RefreshState" />
                            break;
                        case "Quest":
                            <QuestVotePanel GameId="@GameId" PlayerId="@PlayerId" State="@_state" OnAction="@RefreshState" />
                            break;
                        case "QuestResult":
                            <QuestResultPanel GameId="@GameId" PlayerId="@PlayerId" State="@_state" OnAction="@RefreshState" />
                            break;
                        case "AssassinVote":
                            <AssassinPanel GameId="@GameId" PlayerId="@PlayerId" State="@_state" OnAction="@RefreshState" />
                            break;
                        case "LadyOfTheLake":
                            <LadyOfTheLakePanel GameId="@GameId" PlayerId="@PlayerId" State="@_state" OnAction="@RefreshState" />
                            break;
                        case "GameOver":
                            <GameOverPanel GameId="@GameId" PlayerId="@PlayerId" State="@_state" OnAction="@RefreshState" />
                            break;
                        default:
                            <div class="card"><p>Phase: @_state.Phase</p></div>
                            break;
                    }
                }
            </div>
            <div class="panel-chat">
                <ConversationPanel GameId="@GameId" PlayerId="@PlayerId" State="@_state" />
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string GameId { get; set; } = default!;
    [Parameter] public string PlayerId { get; set; } = default!;

    private GameStateResponse? _state;
    private bool _notFound;
    private Action? _eventCallback;

    protected override async Task OnInitializedAsync()
    {
        _eventCallback = async () => await InvokeAsync(async () =>
        {
            await RefreshState();
            StateHasChanged();
        });
        EventBus.Subscribe(GameId, _eventCallback);

        await RefreshState();
    }

    private async Task RefreshState()
    {
        try
        {
            _state = await GameService.GetGameStateAsync(GameId, PlayerId);
        }
        catch (KeyNotFoundException)
        {
            _notFound = true;
        }
        catch
        {
            // Other transient errors
        }
    }

    public void Dispose()
    {
        if (_eventCallback is not null)
        {
            EventBus.Unsubscribe(GameId, _eventCallback);
        }
    }
}
