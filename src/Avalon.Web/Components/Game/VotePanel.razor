@inject GameService GameService

<div class="card">
    <h2>Vote on Team Proposal</h2>

    @if (_currentProposal is not null)
    {
        <table style="width:100%; border:none; border-collapse:collapse;">
            <tr>
                <td style="padding:8px 0;"><strong>Proposed by:</strong> @GetPlayerName(_currentProposal.LeaderPlayerId)</td>
            </tr>
            <tr>
                <td style="padding:8px 0;">
                    <strong>Proposed team:</strong>
                    <div class="player-select" style="margin-top:8px;">
                        @foreach (var id in _currentProposal.ProposedPlayerIds)
                        {
                            <span class="player-chip selected">@GetPlayerName(id)</span>
                        }
                    </div>
                </td>
            </tr>
            @if (State.ConsecutiveRejections > 0)
            {
                <tr>
                    <td style="padding:8px 0;">
                        <span class="error-text">⚠ @State.ConsecutiveRejections/5 consecutive rejections</span>
                    </td>
                </tr>
            }
            <tr>
                <td style="padding:16px 0 0 0;">
                    @if (IsLeader)
                    {
                        <p>Your approval is automatic. You can change your vote to Reject if you wish.</p>
                        <div style="margin-top:12px;">
                            <button class="btn btn-danger" @onclick="() => Vote(VoteType.Reject)">
                                ✗ Change to Reject
                            </button>
                        </div>
                    }
                    else if (HasVoted)
                    {
                        <div class="waiting">
                            <div class="spinner"></div>
                            <p>Vote submitted. Waiting for others to vote...</p>
                        </div>
                    }
                    else
                    {
                        <button class="btn btn-success btn-lg" @onclick="() => Vote(VoteType.Approve)" style="margin-right:10px;">
                            ✓ Approve
                        </button>
                        <button class="btn btn-danger btn-lg" @onclick="() => Vote(VoteType.Reject)">
                            ✗ Reject
                        </button>
                    }
                </td>
            </tr>
        </table>
    }

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="error-text">@_error</div>
    }
</div>

@code {
    [Parameter] public string GameId { get; set; } = default!;
    [Parameter] public string PlayerId { get; set; } = default!;
    [Parameter] public GameStateResponse State { get; set; } = default!;
    [Parameter] public EventCallback OnAction { get; set; }

    private string? _error;

    private ProposalView? _currentProposal =>
        State.Rounds.LastOrDefault()?.Proposals.LastOrDefault();

    private bool IsLeader =>
        _currentProposal?.LeaderPlayerId == PlayerId;

    private bool HasVoted =>
        _currentProposal?.VotedPlayerIds is not null && _currentProposal.VotedPlayerIds.Contains(PlayerId);

    private string GetPlayerName(string playerId) =>
        State.Players.FirstOrDefault(p => p.Id == playerId)?.Name ?? "Unknown";

    private async Task Vote(VoteType vote)
    {
        _error = null;
        try
        {
            await GameService.VoteOnProposalAsync(GameId, PlayerId, vote);
            await OnAction.InvokeAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }
}
