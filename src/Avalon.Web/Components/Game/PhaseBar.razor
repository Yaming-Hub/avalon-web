@inject GameService GameService

@if (State is not null)
{
    <div class="phase-bar">
        <span class="phase-badge">@FormatPhase(State.Phase)</span>

        @if (State.CurrentLeader is not null)
        {
            var leader = State.Players.FirstOrDefault(p => p.Id == State.CurrentLeader);
            <span class="phase-leader">
                Leader: <strong>@(leader?.Name ?? "Unknown")</strong>
            </span>
        }

        @if (State.ConsecutiveRejections > 0)
        {
            <span class="phase-rejections" title="Force-approve at 5 rejections">
                Rejections: @State.ConsecutiveRejections / @GameConfiguration.MaxConsecutiveRejections
            </span>
        }

        <button class="btn btn-sm help-btn" @onclick="ShowHelp" title="What should I do?">❓ Help</button>
        <a class="btn btn-sm help-btn" href="/rules" target="_blank" title="Game rules">📖 Rules</a>
    </div>
}

@code {
    [Parameter] public GameStateResponse? State { get; set; }
    [Parameter] public string GameId { get; set; } = default!;
    [Parameter] public string PlayerId { get; set; } = default!;

    private async Task ShowHelp()
    {
        if (State?.HelpText is not null && !string.IsNullOrEmpty(GameId) && !string.IsNullOrEmpty(PlayerId))
        {
            await GameService.PostChatMessageAsync(GameId, PlayerId, $"[Help] {State.HelpText}");
        }
    }

    private static string FormatPhase(string phase) => phase switch
    {
        "TeamProposal" => "Team Proposal",
        "TeamVote" => "Team Vote",
        "LadyOfTheLake" => "Lady of the Lake",
        "GameOver" => "Game Over",
        _ => phase
    };
}
