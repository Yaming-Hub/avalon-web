@if (State is not null && State.YourRole is not null)
{
    <div class="role-card">
        <img src="/images/@GetCardImage(State.YourRole)" alt="@State.YourRole" />
        <div class="role-card-info">
            <h4>@FormatRoleName(State.YourRole)</h4>
            <span class="team-badge @(State.YourTeam == "Good" ? "team-good" : "team-evil")">
                @State.YourTeam
            </span>

            @if (State.VisiblePlayerIds is { Count: > 0 })
            {
                <p class="visible-players">
                    You can see:
                    @string.Join(", ", State.VisiblePlayerIds
                        .Select(id => State.Players.FirstOrDefault(p => p.Id == id)?.Name ?? id))
                </p>
            }
        </div>
    </div>
}
else
{
    <div class="role-card">
        <div class="role-card-info">
            <h4>Role hidden</h4>
            <span class="team-badge">Unknown</span>
        </div>
    </div>
}

@code {
    [Parameter] public GameStateResponse? State { get; set; }

    private static readonly Dictionary<string, string> RoleImageMap = new()
    {
        ["LoyalServant"] = "card_Loyal_Servant.png",
        ["Merlin"] = "card_Merlin.png",
        ["Percival"] = "card_Percival.png",
        ["Assassin"] = "card_Assassin.png",
        ["Morgana"] = "card_Morgana.png",
        ["Mordred"] = "card_Mordred.png",
        ["Oberon"] = "card_Oberon.png"
    };

    private static string GetCardImage(string role) =>
        RoleImageMap.TryGetValue(role, out var image) ? image : "card_unknown.png";

    private static string FormatRoleName(string role) => role switch
    {
        "LoyalServant" => "Loyal Servant",
        _ => role
    };
}
