@if (State is not null)
{
    <ul class="player-list">
        @foreach (var player in State.Players)
        {
            <li>
                <span class="player-dot @GetDotClass(player)"></span>
                @if (player.IsHost)
                {
                    <span class="player-host" title="Host">👑</span>
                }
                @if (State.CurrentLeader == player.Id)
                {
                    <span class="player-leader" title="Leader">🎯</span>
                }
                <span class="player-name">@player.Name</span>
            </li>
        }
    </ul>
}

@code {
    [Parameter] public GameStateResponse? State { get; set; }

    private string GetDotClass(PlayerView player)
    {
        if (State is null) return "dot-unknown";

        // Show team colour if game is over or player is in visible list
        var isVisible = State.Phase == "GameOver"
            || (State.VisiblePlayerIds is not null && State.VisiblePlayerIds.Contains(player.Id))
            || player.Id == State.YourPlayerId;

        if (!isVisible) return "dot-unknown";

        // During GameOver the server exposes Role/Team on PlayerView
        var team = player.Team;
        if (team is null && player.Id == State.YourPlayerId)
            team = State.YourTeam;

        return team switch
        {
            "Good" => "dot-good",
            "Evil" => "dot-evil",
            _ => "dot-unknown"
        };
    }
}
